{
    "cSpell.words": [
        "buildnode",
        "deathmatch",
        "dockerhub",
        "Dockerized",
        "freeplay",
        "gamesvr",
        "ghcr",
        "laclede's",
        "lacledeslan",
        "LOGFILE",
        "Metamod",
        "qemu",
        "sourcemod",
        "srcds",
        "steamclient",
        "steamcmd",
        "submodules",
        "usercon",
        "usermod",
        "username"
